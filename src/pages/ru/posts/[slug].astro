---
import { getCollection, type CollectionEntry } from 'astro:content';
import Post from '../../../layouts/Post.astro';
import { baseSlug } from '../../../utils/posts';

export async function getStaticPaths() {
  const all = await getCollection('posts');
  return all
    .filter((p) => p.data.lang === 'ru')
    .map((entry) => ({
      params: { slug: baseSlug(entry) },
      props: { entry, all },
    }));
}

interface Props {
  entry: CollectionEntry<'posts'>;
  all: CollectionEntry<'posts'>[];
}

const { entry, all } = Astro.props;
const slug = baseSlug(entry);
const { Content, headings } = await entry.render();

const enCounterpart = all.find(
  (p) => p.data.lang === 'en' && baseSlug(p) === slug,
);
const alternates = {
  ru: `/ru/posts/${slug}/`,
  en: enCounterpart ? `/en/posts/${slug}/` : '/en/',
};
---

<Post
  lang="ru"
  title={entry.data.title}
  date={entry.data.date}
  description={entry.data.description}
  telegram_url={entry.data.telegram_url}
  alternates={alternates}
  headings={headings}
>
  <Content />
</Post>
